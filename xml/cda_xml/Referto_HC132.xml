                    <title>Quesito Diagnostico</title>
                    <text>
                        <paragraph>Sospetto clinico prodromico parkinsoniano in valutazione per inquadramento della vulnerabilità fenotipica.</paragraph>
                    </text>
                </section>
            </component>

            <component>
